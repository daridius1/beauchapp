# ============================================
# Configuración de Beauchapp Backend
# ============================================
# Copia este archivo como .env y llena los valores.
# Luego usa: ./start.sh (en vez de ./pocketbase serve)

# Token de Resend (tu API key)
RESEND_API_KEY=re_xxxxxxxxxx

# (Opcional) Personalizar remitente de correos
SENDER_NAME=Beauchapp
SENDER_ADDRESS=no-reply@daridius.cl

# Cloudflare R2 (S3-compatible storage)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
